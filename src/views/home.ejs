<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Page</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="topnav">
        <a class="active" href="/">Home</a>
        <a href="/create">Create User</a>
    </div>

    <div class="user-list">
        <table class="user-table">
            <tr>
              <th>Id</th>
              <th>Email</th>
              <th>Name</th>
              <th>City</th>
              <th>Action</th>
            </tr>
            <% if (users && users.length > 0) { %>
                <% users.forEach(function(user) { %>
                    <tr>
                      <td><%= user.id %></td>
                      <td><%= user.email %></td>
                      <td><%= user.name %></td>
                      <td><%= user.city %></td>
                      <td class="action-btn">
                        <a class="edit-btn" href="/update/<%= user.id %>">Edit</a>
                        <a class="delete-btn" onclick="openModal()">Delete</a>
                      </td>
                    </tr> 

                    <dialog id="confirmation-modal">
                      <h1>Are you sure</h1>
                      <p>Do you really want to delete this record? This process cannot be undone</p>
                      <button id="close-modal" onclick="closeModal()">Cancel</button>
                      <form action="/delete-user/<%= user.id %>" method="POST"">
                        <button id="delete-user">Delete</button>
                      </form>
                  </dialog>
                <% }) %>
            <% } else { %>
                <tr>
                  <td colspan="4">No users found</td>
                </tr>
            <% } %>
          </table>
    </div>

    

    <script>
      const openModal = () => {
        const modal = document.getElementById('confirmation-modal');
        modal.showModal();
      }

      const closeModal = () => {
        const modal = document.getElementById('confirmation-modal');
        modal.close();
      }
    </script>
</body>
</html>